generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Cliente {
  id             Int           @id
  nome           String
  tipo           String?
  cpfCnpj        String?
  sexo           String?
  dataNascimento DateTime?
  dataCadastro   DateTime?
  status         String?
  telefone       String?
  endereco       Endereco?
  contratos      Contrato[]
  titulos        Titulo[]
  contatos       Contato[]
  notificacoes   Notificacao[]

  @@index([telefone])
}

model Endereco {
  id          Int       @id @default(autoincrement())
  logradouro  String?
  numero      String?
  bairro      String?
  cidade      String?
  uf          String?
  cep         String?
  complemento String?
  latitude    String?
  longitude   String?
  clienteId   Int?      @unique
  contratoId  Int?      @unique
  servicoId   Int?      @unique
  cliente     Cliente?  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  contrato    Contrato? @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  servico     Servico?  @relation(fields: [servicoId], references: [id], onDelete: Cascade)
}

model Contrato {
  id                   Int       @id
  clienteId            Int
  popId                Int?
  dataCadastro         DateTime?
  status               String?
  motivoStatus         String?
  vencimento           Int?
  contratoCentralLogin String?
  contratoCentralSenha String?
  endereco             Endereco?
  servicos             Servico[]
  titulos              Titulo[]
  cliente              Cliente   @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([clienteId])
}

model Servico {
  id             Int       @id
  contratoId     Int
  tipo           String?
  planoId        Int?
  planoDescricao String?
  status         String?
  login          String?
  senha          String?
  mac            String?
  ip             String?
  grupo          String?
  wifiSsid       String?
  wifiPassword   String?
  wifiChannel    String?
  wifiSsid5      String?
  wifiPassword5  String?
  wifiChannel5   String?
  endereco       Endereco?
  contrato       Contrato  @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  @@index([contratoId])
}

model Titulo {
  id               Int           @id
  clienteId        Int
  contratoId       Int?
  portador         String?
  numeroDocumento  Int?
  nossoNumero      String?
  link             String?
  status           String
  valor            Float?
  valorJuros       Float?
  valorMulta       Float?
  valorDesconto    Float?
  valorCorrigido   Float?
  valorPago        Float?
  jurosDia         Float?
  multaDia         Float?
  diasAtraso       Int?
  codigoBarras     String?
  linhaDigitavel   String?
  codigoPix        String?
  dataEmissao      DateTime?
  dataVencimento   DateTime?
  dataPagamento    DateTime?
  dataCancelamento DateTime?
  demonstrativo    String?
  cliente          Cliente       @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  contrato         Contrato?     @relation(fields: [contratoId], references: [id], onDelete: SetNull)
  notificacoes     Notificacao[]

  @@index([clienteId])
  @@index([status, diasAtraso])
  @@index([dataVencimento])
}

model Contato {
  id        Int     @id @default(autoincrement())
  clienteId Int
  tipo      String
  valor     String
  cliente   Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@unique([clienteId, tipo, valor])
}

model Notificacao {
  id             Int       @id @default(autoincrement())
  tituloId       Int
  clienteId      Int
  categoria      String
  referenciaData DateTime
  canal          String
  mensagem       String
  status         String
  tentativas     Int       @default(0)
  enviadoEm      DateTime?
  ultimoErro     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  titulo         Titulo    @relation(fields: [tituloId], references: [id], onDelete: Cascade)
  cliente        Cliente   @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@unique([tituloId, categoria, referenciaData])
  @@index([status])
  @@index([clienteId])
  @@index([tituloId])
}

model Session {
  id           String   @id @default(uuid())
  telefone     String   @unique
  estado       String
  contexto     String?
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

model MediaLog {
  id         String   @id @default(uuid())
  telefone   String
  tipo       String
  mediaUrl   String?
  recebidoEm DateTime @default(now())
}
