{
  "name": "sgp-whatsapp-bot-simple",
  "version": "1.0.0",
  "description": "SGP WhatsApp bot with NestJS, Prisma and PostgreSQL",
  "private": true,
  "license": "MIT",
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "nodemon --exec ts-node -r tsconfig-paths/register src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "sync": "ts-node -r tsconfig-paths/register src/modules/sync/sync.cli.ts",
    "prisma:generate": "prisma generate",
    "prisma:dbpush": "prisma db push"
  },
  "dependencies": {
    "@nestjs/axios": "^3.1.1",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/schedule": "^4.0.0",
    "@nestjs/throttler": "^6.0.0",
    "@prisma/client": "^5.18.0",
    "axios": "^1.7.7",
    "baileys": "^6.7.9",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/express": "^4.17.21",
    "@types/qrcode": "^1.5.6",
    "nodemon": "^3.1.9",
    "prisma": "^5.18.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.4"
  }
}
